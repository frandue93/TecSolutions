---
export interface Props {
  title: string;
  short: string;
  image: string;
  slug: string;
  bgSize?: string;
  bgPosition?: string;
}
const { title, short, image, slug, bgSize = 'cover', bgPosition = 'center 0px, center center' } = Astro.props;

function slugify(s: string) {
  return (s || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}
const href = `/servicios/${slug ?? slugify(title)}`;
---
<a href={href} class="group block" aria-label={title}>
  <article
    class="relative p-6 rounded-lg border transition duration-300 transform hover:-translate-y-1 overflow-hidden border-blue-600/50 hover:border-blue-500"
    style={`
      background-image: linear-gradient(to bottom, rgba(17, 24, 39, 0.85) 60%, rgba(17, 24, 39, 1) 70%), url('${image}');
      background-size: ${bgSize};
      background-position: ${bgPosition};
      background-color: #111827;
    `}
    itemscope itemtype="http://schema.org/Service"
  >
    <div class="absolute inset-0 bg-gradient-to-b from-blue-900/50 to-gray-800 opacity-90 group-hover:opacity-100 transition duration-300" aria-hidden="true"></div>

    <div class="relative z-10" itemprop="provider" itemscope itemtype="http://schema.org/Organization">
      <meta itemprop="name" content="Consultoría Tecnológica" />
      <div class="text-blue-400 mb-4" aria-hidden="true">
        <svg class="w-8 h-8 transition-transform duration-300 group-hover:animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15a3 3 0 100-6 3 3 0 000 6z"></path></svg>
      </div>

      <h3 class="text-xl font-semibold text-white mb-2 group-hover:text-blue-400 transition-colors" itemprop="name">{title}</h3>
      <p class="text-gray-300 text-sm mb-4" itemprop="description">{short}</p>
      
      <div class="mt-4">
        <span class="inline-flex items-center px-4 py-2 text-sm font-medium rounded-full bg-blue-600 group-hover:bg-blue-700 text-white shadow-sm transition-all duration-300">
          Leer más
          <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </span>
      </div>
    </div>
  </article>
</a>