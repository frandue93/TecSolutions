---

import '../styles/global.css';
import MobileMenu from '../components/MobileMenu.jsx';

export interface Props {
    title: string;
    description: string; // ¡Nueva propiedad necesaria!
    image?: string;      // Opcional para Open Graph
    url?: string;        // Opcional para Open Graph (URL canónica)
}

const { 
    title, 
    description, 
    image = '/images/default-seo.jpg', // Imagen por defecto
    url = Astro.url.href 
} = Astro.props;

---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="canonical" href={url} />

    <title>{title}</title>
    <meta name="description" content={description} />
    
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <!-- <meta property="og:image" content={new URL(image, Astro.site).href} /> -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@TuHandleDeTwitter" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="stylesheet" href="/src/styles/global.css" />
    <!-- <meta name="twitter:image" content={new URL(image, Astro.site).href} /> -->


</head>

<body class="bg-gray-900 text-gray-200 font-sans min-h-screen flex flex-col">
<header id="header" class="shadow-md p-4 sticky top-0 z-50 hero-section transition-all duration-300">
<nav class="container mx-auto flex justify-between items-center relative rounded-full px-6 py-3 shadow-lg
    bg-[radial-gradient(ellipse_at_center,_white_20%,_white_75%,_#1f2937_100%),linear-gradient(to_bottom,_white_0%,_white_40%,_#1f2937_100%)]">


            <a href="/" class="flex items-center">
                <img src="/images/iconoAlfaroMenuAncho.png" alt="Logo Alfaro Consultora" class="h-12 w-auto transparent-image my-2 ml-6 " />
            </a>
            
            <a href="/" class="absolute left-1/2 transform -translate-x-1/2">
                <img src="/images/LetrasAlfaroMenu.png" alt="Logo Nombre Alfaro Consultora" class="h-12 w-auto transparent-image" />
            </a>
            
            <div class="hidden md:block space-x-4">
                <a href="/servicios" class="text-black hover:text-blue-400">Servicios</a>
                <a href="/acerca" class="text-black hover:text-blue-400">Acerca de</a>
                <a href="/contacto" class="px-4 py-2 bg-blue-700 text-white rounded hover:bg-blue-800">Contacto</a>
            </div>
            
            <MobileMenu client:load /> 
        </nav>
    </header>

    <main class="container mx-auto my-8 p-4 flex-grow ">
        <slot />
    </main>

    <footer class="bg-gray-950 text-gray-400 p-8 mt-12">
        <div class="container mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-6">
                <!-- Columna 1: Info -->
                <div>
                    <h3 class="text-white font-bold mb-3">Tu Consultoria Tecnológica</h3>
                    <p class="text-sm">Soluciones tecnológicas innovadoras para empresas B2B.</p>
                </div>
                
                <!-- Columna 2: Enlaces -->
                <div>
                    <h3 class="text-white font-bold mb-3">Legal</h3>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/politica-privacidad" class="hover:text-blue-400 transition-colors">Política de Privacidad</a></li>
                        <li><a href="/politica-cookies" class="hover:text-blue-400 transition-colors">Política de Cookies</a></li>
                        <li><a href="/aviso-legal" class="hover:text-blue-400 transition-colors">Aviso Legal</a></li>
                    </ul>
                </div>
                
                <!-- Columna 3: Redes Sociales -->
                <div>
                    <h3 class="text-white font-bold mb-3">Síguenos</h3>
                    <div class="flex space-x-4">
                        <span
                            class="text-gray-400"
                            aria-label="LinkedIn desactivado"
                        >
                            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                            </svg>
                        </span>
                    </div>
                </div>
            </div>
            
            <div class="border-t border-gray-800 pt-6 text-center text-sm">
                <p>&copy; {new Date().getFullYear()} Tu Consultoria Tecnológica. Todos los derechos reservados.</p>
            </div>
        </div>
    </footer>

    <script>
        let lastScroll = 0;
        const header = document.getElementById('header');
        
        // Ocultar el header inicialmente en la página de inicio
        if (window.location.pathname === '/' || window.location.pathname === '/index.html') {
            header.style.opacity = '0';
            
            // Mostrar con fade in después de 2 segundos
            setTimeout(() => {
                header.style.opacity = '1';
            }, 2000);
        }
        
        window.addEventListener('scroll', () => {
            const currentScroll = window.pageYOffset;
            
            if (currentScroll <= 0) {
                header.style.opacity = '1';
                return;
            }
            
            if (currentScroll > lastScroll && currentScroll > 100) {
                // Scroll hacia abajo - ocultar
                header.style.opacity = '0';
            } else if (currentScroll < lastScroll) {
                // Scroll hacia arriba - mostrar
                header.style.opacity = '1';
            }
            
            lastScroll = currentScroll;
        });
    </script>
</body>
</html>