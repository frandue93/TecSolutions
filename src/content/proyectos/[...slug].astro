---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';


export async function getStaticPaths() {

    const proyectos = await getCollection('proyectos');
    

    return proyectos.map(entry => ({
        params: { slug: entry.slug }, 
        props: { entry },             
    }));
}

const { entry } = Astro.props;
const { Content } = await entry.render(); 

const { title, client, date, technologies } = entry.data;

const formattedDate = date.toLocaleDateString('es-ES', { 
    year: 'numeric', 
    month: 'long', 
    day: 'numeric' 
});
---
<BaseLayout title={title + " | Caso de Estudio"} description={`Caso de estudio del proyecto ${title} para ${client}`}>
    <article class="prose lg:prose-xl max-w-none">
        <header class="mb-10 border-b pb-4">
            <h1 class="text-5xl font-extrabold text-blue-800 mb-2">{title}</h1>
            <p class="text-lg text-gray-600">Cliente: <strong>{client}</strong> | Fecha: {formattedDate}</p>
            
            <div class="mt-4 flex flex-wrap gap-2">
                {technologies.map((tech: string) => (
                    <span class="bg-blue-100 text-blue-800 text-xs font-medium px-3 py-1 rounded-full">{tech}</span>
                ))}
            </div>
        </header>

        <div class="text-gray-700">
            <Content />
        </div>
    </article>
</BaseLayout>