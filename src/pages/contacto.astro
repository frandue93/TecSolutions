---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contacto | Consultoría Tecnológica" description="Contáctanos para una consulta tecnológica personalizada. Te respondemos en menos de 24 horas para agendar tu consulta inicial.">
    <div class="py-12 px-4">
        <section class="max-w-4xl mx-auto">
            <!-- Header Section -->
            <div class="text-center mb-12">
                <h1 class="text-5xl font-bold text-white mb-4">
                    Hablemos de tu <span class="text-blue-400">Proyecto</span>
                </h1>
                <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
                    Envíanos un mensaje y te contactaremos en menos de 24 horas para agendar una consulta inicial gratuita.
                </p>
            </div>

            <!-- Contact Form Card -->
            <div class="bg-gray-800 rounded-2xl shadow-2xl border border-gray-700 overflow-hidden">
                <div class="bg-gradient-to-r from-blue-600 to-blue-500 p-8">
                    <h2 class="text-2xl font-semibold text-white text-center">
                        Consultoría Tecnológica Personalizada
                    </h2>
                    <p class="text-blue-100 text-center mt-2">
                        Cuéntanos sobre tu desafío y te ayudaremos a encontrar la mejor solución
                    </p>
                </div>

                <div class="p-8 lg:p-12">
                    <div class="mb-6 rounded-lg border border-gray-600 bg-gray-900/40 p-4 text-sm text-gray-300">
                        <p>
                            También puedes escribirnos directamente por email:
                            <a id="direct-email-link" href="#" class="text-blue-400 hover:text-blue-300 transition-colors" aria-label="Enviar email directo">
                                Cargar email
                            </a>
                        </p>
                    </div>
                    <form method="POST" action="/api/contact" class="space-y-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="name" class="block text-sm font-semibold text-gray-200 mb-2">
                                    Nombre Completo *
                                </label>
                                <input type="text" id="name" name="name" required 
                                       class="w-full px-4 py-3 border-2 border-gray-600 rounded-lg shadow-sm focus:border-blue-400 focus:ring-2 focus:ring-blue-500/20 transition-all duration-200 bg-gray-700 text-white placeholder-gray-400 focus:bg-gray-600">
                            </div>

                            <div>
                                <label for="email" class="block text-sm font-semibold text-gray-200 mb-2">
                                    Email Corporativo *
                                </label>
                                <input type="email" id="email" name="email" required 
                                       class="w-full px-4 py-3 border-2 border-gray-600 rounded-lg shadow-sm focus:border-blue-400 focus:ring-2 focus:ring-blue-500/20 transition-all duration-200 bg-gray-700 text-white placeholder-gray-400 focus:bg-gray-600">
                            </div>
                        </div>

                        <div>
                            <label for="company" class="block text-sm font-semibold text-gray-200 mb-2">
                                Empresa (Opcional)
                            </label>
                            <input type="text" id="company" name="company" 
                                   class="w-full px-4 py-3 border-2 border-gray-600 rounded-lg shadow-sm focus:border-blue-400 focus:ring-2 focus:ring-blue-500/20 transition-all duration-200 bg-gray-700 text-white placeholder-gray-400 focus:bg-gray-600">
                        </div>

                        <div>
                            <label for="message" class="block text-sm font-semibold text-gray-200 mb-2">
                                Descripción del Proyecto *
                            </label>
                            <textarea id="message" name="message" rows="5" required 
                                      placeholder="Cuéntanos sobre tu proyecto, desafíos técnicos, objetivos y timeline..."
                                      class="w-full px-4 py-3 border-2 border-gray-600 rounded-lg shadow-sm focus:border-blue-400 focus:ring-2 focus:ring-blue-500/20 transition-all duration-200 bg-gray-700 text-white placeholder-gray-400 focus:bg-gray-600 resize-none"></textarea>
                        </div>

                        <div class="bg-gray-750 rounded-lg p-6 border border-gray-600">
                            <h3 class="text-lg font-semibold text-gray-100 mb-3">¿En qué te podemos ayudar?</h3>
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                <label class="flex items-center space-x-2 cursor-pointer">
                                    <input type="checkbox" name="services" value="desarrollo" class="rounded border-gray-500 text-blue-500 focus:ring-blue-500 bg-gray-700">
                                    <span class="text-sm text-gray-300">Desarrollo de Software</span>
                                </label>
                                <label class="flex items-center space-x-2 cursor-pointer">
                                    <input type="checkbox" name="services" value="cloud" class="rounded border-gray-500 text-blue-500 focus:ring-blue-500 bg-gray-700">
                                    <span class="text-sm text-gray-300">Consultoría Cloud</span>
                                </label>
                                <label class="flex items-center space-x-2 cursor-pointer">
                                    <input type="checkbox" name="services" value="seo" class="rounded border-gray-500 text-blue-500 focus:ring-blue-500 bg-gray-700">
                                    <span class="text-sm text-gray-300">SEO Técnico</span>
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-blue-500 text-white py-4 px-8 rounded-lg font-semibold text-lg shadow-lg hover:from-blue-700 hover:to-blue-600 transform hover:-translate-y-0.5 transition-all duration-200 focus:outline-none focus:ring-4 focus:ring-blue-500/30">
                            <span class="flex items-center justify-center space-x-2">
                                <span>Enviar Solicitud de Consultoría</span>
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                                </svg>
                            </span>
                        </button>
                    </form>
                </div>
            </div>

            <!-- Contact Info -->
            <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
                <div class="bg-gray-800 rounded-lg p-6 shadow-lg border border-gray-700">
                    <div class="text-blue-400 text-3xl mb-3">⚡</div>
                    <h3 class="font-semibold text-gray-100 mb-2">Respuesta Rápida</h3>
                    <p class="text-gray-300 text-sm">Te contactamos en menos de 24 horas</p>
                </div>
                <div class="bg-gray-800 rounded-lg p-6 shadow-lg border border-gray-700">
                    <div class="text-blue-400 text-3xl mb-3">💼</div>
                    <h3 class="font-semibold text-gray-100 mb-2">Consulta Gratuita</h3>
                    <p class="text-gray-300 text-sm">Primera sesión sin compromiso</p>
                </div>
                <div class="bg-gray-800 rounded-lg p-6 shadow-lg border border-gray-700">
                    <div class="text-blue-400 text-3xl mb-3">🎯</div>
                    <h3 class="font-semibold text-gray-100 mb-2">Soluciones Personalizadas</h3>
                    <p class="text-gray-300 text-sm">Adaptadas a tus necesidades específicas</p>
                </div>
            </div>
        </section>
    </div>

    <script>
        const directEmailLink = document.getElementById('direct-email-link');
        const user = 'techsolutionsalfaro';
        const domain = 'gmail.com';
        const email = `${user}@${domain}`;

        if (directEmailLink) {
            directEmailLink.setAttribute('href', `mailto:${email}`);
            directEmailLink.textContent = email;
        }
    </script>
</BaseLayout>