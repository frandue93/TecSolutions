---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { services } from '../../data/services';

export const prerender = true;

export async function getStaticPaths() {
  return services.map(s => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const service = services.find(s => s.slug === slug);

if (!service) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={`${service.title} | Consultoría Tecnológica`} description={service.short}>
  <article class="max-w-4xl mx-auto">
    <!-- Hero Section con imagen -->
    <div class="relative h-64 md:h-96 rounded-xl overflow-hidden mb-8">
      <img 
        src={service.image} 
        alt={service.title} 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/50 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 p-8">
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">{service.title}</h1>
        <p class="text-lg text-gray-200">{service.short}</p>
      </div>
    </div>

    <!-- Contenido principal -->
    <div class="bg-gray-800 rounded-xl p-8 md:p-12 mb-8">
      <h2 class="text-2xl font-bold text-white mb-6">Descripción del Servicio</h2>
      <p class="text-gray-300 text-lg leading-relaxed mb-8">{service.full}</p>

      <div class="border-t border-gray-700 pt-8">
        <h3 class="text-xl font-bold text-white mb-4">¿Por qué elegir este servicio?</h3>
        <ul class="space-y-3 text-gray-300">
          <li class="flex items-start">
            <svg class="w-6 h-6 text-blue-400 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Soluciones personalizadas adaptadas a tu empresa</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-blue-400 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Equipo de expertos con experiencia demostrada</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-blue-400 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Soporte continuo y mantenimiento garantizado</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-blue-400 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Resultados medibles y ROI comprobable</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="bg-gradient-to-r from-blue-600 to-indigo-600 rounded-xl p-8 md:p-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
        ¿Listo para impulsar tu negocio?
      </h2>
      <p class="text-blue-100 text-lg mb-6">
        Agenda una consulta gratuita y descubre cómo podemos ayudarte
      </p>
      <a 
        href="/contacto" 
        class="inline-block px-8 py-4 bg-white text-blue-600 font-semibold rounded-full hover:bg-gray-100 transition-all duration-300 transform hover:scale-105 shadow-lg"
      >
        Contactar Ahora
      </a>
    </div>

    <!-- Navegación a otros servicios -->
    <div class="mt-12">
      <h3 class="text-xl font-bold text-white mb-6">Otros Servicios</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {services.filter(s => s.slug !== slug).slice(0, 3).map(otherService => (
          <a 
            href={`/servicios/${otherService.slug}`}
            class="bg-gray-800 rounded-lg p-6 hover:bg-gray-750 transition-colors duration-300 group"
          >
            <h4 class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors mb-2">
              {otherService.title}
            </h4>
            <p class="text-gray-400 text-sm">{otherService.short}</p>
          </a>
        ))}
      </div>
    </div>
  </article>
</BaseLayout>
